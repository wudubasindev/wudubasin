# Supabase configuration
# Copy this file to .env.local and fill in your real keys.
# Get these from: Supabase Dashboard > Project Settings > API

# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://dkmgrnrvvdxyhjstumkh.supabase.co

# Public anon key (safe to expose to the browser; protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER-SIDE ONLY - never expose to the browser, never commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe configuration (deposit payments)
# Get this from: Stripe Dashboard > Developers > API keys
# SERVER-SIDE ONLY - never expose to the browser, never commit.
# sk_test_... is fine for local development; switch to sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Price object for the booking deposit
# Get this from: Stripe Dashboard > Product catalog > WuduBasin.ca Installation Deposit
STRIPE_DEPOSIT_PRICE_ID=price_your-price-id-here

# Signing secret for the /api/stripe/webhook endpoint
# Get this from: Stripe Dashboard > Developers > Webhooks > (your endpoint) > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Resend configuration (booking confirmation emails)
# Get this from: Resend Dashboard > API Keys
# SERVER-SIDE ONLY - never expose to the browser, never commit.
RESEND_API_KEY=re_your-api-key-here

# Sender address used for confirmation emails. Must be a verified domain in Resend,
# or use the shared onboarding@resend.dev sender for testing.
RESEND_FROM_EMAIL="WuduBasin.ca <onboarding@resend.dev>"
